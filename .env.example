# 크로스디바이스 동기화용 KV(Upstash Redis) 자격증명.
# 이 값이 있으면 Redis에 저장(여러 기기·서버리스 인스턴스 간 공유),
# 없으면 로컬 인메모리로 자동 폴백한다(로컬 개발엔 설정 불필요).
#
# Vercel에서: Storage 탭 → Upstash Redis(또는 KV) 연동하면 아래 KV_* 변수가
# 프로젝트에 자동 주입된다. 로컬에서 KV로 테스트하려면 .env.local에 복사해 채운다.

# Vercel KV / Marketplace 연동 시 자동 주입되는 이름
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash 콘솔에서 직접 만들 때의 이름(둘 중 하나만 있으면 됨)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
